# Copy to `.env` and fill in values.

# Supabase (required for auth, saved questions, support resources, glossary)
# Project: OHHF Database — ref rcytzbgwjbftajtykxxr
VITE_SUPABASE_URL=https://rcytzbgwjbftajtykxxr.supabase.co
VITE_SUPABASE_ANON_KEY=

# Server-only (Settings → API → service_role). Used by npm run server:dev for mood/journal saves.
SUPABASE_SECRET_KEY=

# One OpenAI key powers embeddings (rag:build + retrieval) and chat completions.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
# OPENAI_FOLLOWUP_MODEL=gpt-4o-mini

# After OPENAI_API_KEY is set:
#   npm run rag:build    → writes data/knowledge/index.json
#   npm run server:dev   → API on :3001
#   npm run dev          → Vite (proxies /api to :3001)
